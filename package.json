{
  "name": "typing-race",
  "private": true,
  "version": "0.0.0",
  "description": "Frictionless real-time 2-player typing race. Share a link, race within 10s.",
  "workspaces": [
    "web",
    "worker"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @typing-race/web",
    "dev:worker": "npm run dev -w @typing-race/worker",
    "build:web": "npm run build -w @typing-race/web",
    "typecheck:worker": "npm run typecheck -w @typing-race/worker",
    "deploy:worker": "npm run deploy -w @typing-race/worker",
    "deploy:web": "wrangler pages deploy web/dist --project-name=typing-race --branch=main --commit-dirty=true"
  }
}
